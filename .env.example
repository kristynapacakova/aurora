# --- Varianta A: Formspree (jednodušší, doporučeno) ---
# URL formuláře vytvořeného na https://formspree.io (např. https://formspree.io/f/abcd1234)
# Pokud necháte prázdné, použije se varianta B (Resend, /api/objednavka).
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# --- Varianta B: Resend (vlastní API route) ---
# API klíč z https://resend.com
RESEND_API_KEY=
# E-mail, na který chodí nové objednávky
RESEND_TO_EMAIL=
# Odesílací adresa - musí být na ověřené doméně v Resendu
RESEND_FROM_EMAIL=

# --- Členská sekce /studium ---
# Přístupový kód pro vstup do členské sekce (výchozí: Namaste2026)
# Kontroluje se na serveru (API route), není vidět v JS bundlu.
STUDIO_ACCESS_CODE=Namaste2026

# Tajný klíč pro podepisování session cookie členské sekce.
# Vygenerujte si vlastní náhodný řetězec, např. pomocí: openssl rand -hex 32
STUDIO_COOKIE_SECRET=zmente-me-na-nahodny-tajny-retezec
